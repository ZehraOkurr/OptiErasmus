@page
@model IndexModel
@{
    ViewData["Title"] = "OptiErasmus";
}

<!-- Premium Hero Background Decals -->
<div style="position: absolute; top: -150px; right: -150px; width: 680px; height: 680px; background-color: #FFF1DA; border-radius: 50%; opacity: 0.7; z-index: -1;"></div>
<div style="position: absolute; top: 100px; left: -100px; width: 200px; height: 200px; background-color: #FFE5E0; border-radius: 50%; opacity: 0.5; z-index: -1;"></div>

<div class="row align-items-center min-vh-75 py-5 mb-5 ps-lg-4">
    <div class="col-lg-6 pe-lg-5 position-relative z-1">
        <h6 class="fw-bold mb-3" style="color: var(--accent-coral); letter-spacing: 2px; text-transform: uppercase; font-family: 'Poppins', sans-serif;">
            En İYİ Erasmus HEDEFLERİ
        </h6>
        <h1 class="display-3 fw-bold mb-4" style="line-height: 1.25;">
            Keşfet, oku ve <br>
            <span style="position:relative; z-index:1;">
                en iyi
                <svg style="position:absolute; bottom:-5px; left:0; width:100%; z-index:-1;" viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
                    <path d="M0,15 Q100,0 200,15" stroke="var(--accent-coral)" stroke-width="6" fill="none" stroke-linecap="round" />
                </svg>
            </span>
            Erasmus <br>hayatını yaşa
        </h1>
        <p class="fs-5 mb-5" style="color: var(--secondary-text); line-height: 1.8;">
            Biz sadece tahminde bulunmuyoruz. GDELT ve Numbeo veritabanlarından çekilen on binlerce canlı veriyle
            senin için en güvenli, ekonomik ve akademik açıdan parlak şehri haritalandırıyoruz.
        </p>

        <div class="d-flex flex-wrap gap-4 align-items-center">
            <a href="/Rehber" class="btn btn-brand rounded-3 px-4 py-3 fw-bold shadow">
                Şehirleri İncele
            </a>
            <a href="/Anket" class="btn border-0 fw-bold d-flex align-items-center" style="color: var(--secondary-text); background: transparent;">
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle shadow me-3" style="width: 54px; height: 54px; background: var(--accent-coral); color: white; transition: 0.3s; transform: scale(1);" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                    <i class="bi bi-play-fill fs-3" style="margin-left: 3px;"></i>
                </span>
                Sihirbazı Başlat
            </a>
        </div>
    </div>

    <div class="col-lg-6 mt-5 mt-lg-0 position-relative z-1 text-center">
        <div class="position-relative d-inline-block">
            <div class="card border-0 shadow-lg" style="border-radius: 40px; overflow: hidden; background: white; max-width: 420px;">
                <div class="card-body p-5 p-md-5 text-start">
                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-box me-3 p-3 rounded-circle text-white shadow-sm" style="background: var(--accent-orange);">
                            <i class="bi bi-database-fill-check fs-4"></i>
                        </div>
                        <div>
                            <!-- Dinamik Veri Satırı Sayısı -->
                            <h4 class="mb-0 fw-bold" style="font-family: 'Noto Sans', sans-serif;">@Model.TotalRows.ToString("N0")</h4>
                            <p class="text-muted small mb-0 font-monospace">ISLENEN_VERI_SATIRI</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-box me-3 p-3 rounded-circle text-white shadow-sm" style="background: var(--primary-navy);">
                            <i class="bi bi-shield-check fs-4"></i>
                        </div>
                        <div>
                            <!-- Dinamik Lokasyon Sayısı -->
                            <h4 class="mb-0 fw-bold" style="font-family: 'Noto Sans', sans-serif;">@Model.TotalCities Farklı</h4>
                            <p class="text-muted small mb-0 font-monospace">AVRUPA_LOKASYONU</p>
                        </div>
                    </div>

                    <hr class="my-4" style="opacity: 0.1;">
                    <h6 class="fw-bold mb-3" style="color: var(--primary-navy);">Global Güvenlik Dağılımı</h6>
                    <div id="donutChart" style="min-height: 250px;"></div>
                </div>
            </div>

            <div class="card border-0 shadow-lg position-absolute" style="bottom: -30px; right: -40px; border-radius: 20px; background: white; z-index: 2; border: 1px solid rgba(0,0,0,0.02);">
                <div class="card-body p-3 px-4 d-flex align-items-center gap-3">
                    <div class="rounded-circle p-2" style="background: rgba(43, 147, 72, 0.1);">
                        <i class="bi bi-graph-up-arrow text-success fs-3"></i>
                    </div>
                    <div class="text-start">
                        <p class="text-muted small mb-0 fw-bold" style="font-size: 0.75rem;">MATEMATİKSEL KANIT</p>
                        <h6 class="fw-bold mb-0" style="color:var(--primary-navy);">VIKOR & BWM</h6>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- CATEGORY Section -->
<div class="text-center mb-5 pb-5 mt-5 pt-5">
    <p class="fw-bold mb-2" style="color: var(--secondary-text); letter-spacing: 2px; text-transform: uppercase;">KATEGORİ</p>
    <h2 class="display-5 fw-bold mb-5 pb-4">Sunulan Hizmetler</h2>

    <div class="row g-4 position-relative z-1 pt-3">
        <div style="position: absolute; top: -30px; right: 20px; font-size: 8rem; color: #FFF1DA; z-index: -1; line-height: 1;">+ ＋</div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-none h-100 service-card text-center p-4 bg-transparent">
                <div class="card-body">
                    <div class="mb-4 mx-auto rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: #FFF1DA; color: var(--accent-orange); font-size: 2.2rem;">
                        <i class="bi bi-globe-americas"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Global Veri Analizi</h5>
                    <p class="text-muted px-2" style="line-height: 1.7;">GDELT üzerinden haber etkinlikleri ve duyarlılık (tone) analizleriyle şehirlerin global profilini çıkarıyoruz.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 h-100 service-card text-center p-4 bg-white" style="box-shadow: 0 25px 50px rgba(0,0,0,0.06); border-radius: 36px; z-index: 2; position: relative;">
                <div style="position:absolute; width:100px; height:100px; background: var(--accent-coral); bottom: -20px; left: -20px; z-index:-1; border-radius: 20px 0 20px; opacity: 0.9;"></div>

                <div class="card-body bg-white rounded-5 z-2 position-relative pt-3">
                    <div class="mb-4 mx-auto rounded-circle d-flex align-items-center justify-content-center shadow-lg" style="width: 80px; height: 80px; background: var(--accent-coral); color: white; font-size: 2.2rem;">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Güvenlik Endeksi</h5>
                    <p class="text-muted px-2" style="line-height: 1.7;">Gideceğiniz ülkenin asayiş ve sosyal barış durumunu, @Model.TotalRows.ToString("N0")'dan fazla verinin ışığında analiz edip net olarak puanlıyoruz.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-none h-100 service-card text-center p-4 bg-transparent">
                <div class="card-body">
                    <div class="mb-4 mx-auto rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background: rgba(24, 30, 75, 0.05); color: var(--primary-navy); font-size: 2.2rem;">
                        <i class="bi bi-calculator-fill"></i>
                    </div>
                    <h5 class="fw-bold mb-3">Yapay Zeka BWM</h5>
                    <p class="text-muted px-2" style="line-height: 1.7;">Sizin değerlerinize en uygun opsiyonu matematiksel üstünlük formülleri (VIKOR algoritması) ile %100 tarafsız hesaplıyoruz.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .service-card {
        transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .service-card:hover {
            transform: translateY(-10px);
        }
</style>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
    var optionsDonut = {
    series: [35, 45, 15, 5],
    chart: { type: 'donut', height: 280, background: 'transparent' },
    labels: ['Güçlü', 'Güvenli', 'Orta', 'Riskli'],
    colors: ['#2B9348', '#f1a501', '#df6951', '#181e4b'],
    plotOptions: {
    donut: {
    size: '72%',
    labels: { show: true, name: { show: true, color: '#5e6282' }, value: { show: true, fontWeight: 700, color: '#181e4b' } }
    }
    },
    legend: { show: false },
    dataLabels: { enabled: false },
    stroke: { show: true, width: 3, colors: ['#fff'] }
    };
    new ApexCharts(document.querySelector("#donutChart"), optionsDonut).render();
    });
</script>