@page "/deneyim"
@model OptiErasmus.Pages.DeneyimModel
@using System.Text.Json
@using OptiErasmus.Services
@{
    ViewData["Title"] = "Geçmiş Erasmus Deneyimleri";
    var cmp = Model.Comparison;
}

<div style="position:absolute;top:-120px;right:-120px;width:480px;height:480px;background:#FFF1DA;border-radius:50%;opacity:.6;z-index:-1;"></div>

<div class="text-center mb-5 pt-3">
    <p class="fw-bold mb-2" style="color:var(--secondary-text);letter-spacing:2px;text-transform:uppercase;">ÖĞRENCİ DENEYİMİ</p>
    <h1 class="display-5 fw-bold mb-3">Geçmiş Erasmus Öğrencileri Verisi</h1>
    <p class="text-muted fs-5 mx-auto" style="max-width:720px;">
        Gerçek öğrenci anketleri ile VIKOR model önerileri yan yana karşılaştırılır.
    </p>
</div>

<div class="row g-4 mb-5">
    <div class="col-lg-5">
        <div class="card premium-card h-100">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex align-items-center mb-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width:48px;height:48px;background:#FFF1DA;color:var(--accent-orange);">
                        <i class="bi bi-clipboard-check fs-4"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0" style="color: var(--primary-navy);">Deneyim Anketi</h4>
                        <small class="text-muted">Erasmus deneyimini paylaş</small>
                    </div>
                </div>

                <form id="alumniForm">
                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="color: var(--primary-navy);">Nereye gittiniz?</label>
                        <select class="form-select rounded-3" id="city" required style="border: 2px solid #e2e8f0; font-size: 1rem; padding: 12px 16px;">
                            <option value="">Gittiğiniz şehri seçiniz</option>
                            @foreach (var city in Model.Cities)
                            {
                                <option value="@city">@city</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="color: var(--primary-navy);">Memnuniyet Dereceniz (1–5)</label>
                        <div class="d-flex gap-3 flex-wrap my-2" id="satisfactionGroup">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <input type="radio" class="btn-check" name="satisfaction" id="sat@i" value="@i" @(i == 4 ? "checked" : "")>
                                <label class="satisfaction-btn" for="sat@i">@i</label>
                            }
                        </div>
                        <small class="text-muted"><i class="bi bi-info-circle me-1"></i> 1 = Hiç memnun değilim, 5 = Çok memnunum</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="color: var(--primary-navy);">Tekrar tercih eder miydiniz?</label>
                        <div class="d-flex gap-3 my-2">
                            <input type="radio" class="btn-check" name="again" id="againYes" value="true" checked>
                            <label class="btn pill-select-btn btn-yes px-4 py-2" for="againYes">
                                <i class="bi bi-hand-thumbs-up-fill"></i> Evet
                            </label>
                            
                            <input type="radio" class="btn-check" name="again" id="againNo" value="false">
                            <label class="btn pill-select-btn btn-no px-4 py-2" for="againNo">
                                <i class="bi bi-hand-thumbs-down-fill"></i> Hayır
                            </label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="color: var(--primary-navy);">En önemli önceliğiniz neydi?</label>
                        <select class="form-select rounded-3" id="criterion" required style="border: 2px solid #e2e8f0; font-size: 1rem; padding: 12px 16px;">
                            <option value="cost">Ekonomi (Uygunluk)</option>
                            <option value="security">Güvenlik (Huzur)</option>
                            <option value="academic">Akademik Kalite</option>
                            <option value="social">Sosyal Yaşam</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-lg w-100 fw-bold text-white border-0 py-3 mt-2" style="background:linear-gradient(135deg,var(--accent-orange),var(--accent-coral));border-radius:14px;box-shadow: 0 4px 15px rgba(239, 105, 81, 0.3);transition: all 0.3s;">
                        <i class="bi bi-send me-2"></i>Deneyimimi Paylaş
                    </button>
                    <div id="formAlert" class="alert mt-3 d-none"></div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card gradient-glass-card h-100">
            <div class="card-body p-4 p-lg-5 d-flex flex-column justify-content-between">
                <div>
                    <span class="badge bg-warning text-dark mb-4 px-4 py-3 fw-semibold rounded-pill fs-5" style="display: inline-flex; align-items: center; justify-content: center;">
                        <i class="bi bi-sliders me-2" style="font-size: 1.2rem;"></i> Karşılaştırma Özeti
                    </span>                    
                    <h3 class="fw-bold mb-3" style="font-family: 'Volkhov', serif; line-height: 1.4; color: #e2e8f0; text-align: center;">Model Önerileri ile Gerçek Öğrenci Deneyimleri Karşılaştırılmıştır</h3>
                    <p class="opacity-75 mb-4" style="line-height: 1.7; color: #e2e8f0; text-align: center;">
                        VIKOR-BWM karar modelleri ile analiz yapılır ; öğrenci anketi ise geçmiş öğrencilerin memnuniyet ve tercih verilerini yansıtır.
                        Platformumuz bu iki katmanı matematiksel korelasyon ile karşılaştırır ve karar vermenizde yardımcı olmayı hedefler.
                    </p>
                </div>
                <div class="row g-3 text-center mt-auto">
                    <div class="col-4">
                        <div class="p-3 rounded-4 border" style="background: rgba(255, 255, 255, 0.05); border-color: rgba(255, 255, 255, 0.08) !important;">
                            <div class="fs-2 fw-bold text-warning" id="statResponses">@cmp.TotalResponses</div>
                            <small class="opacity-75 d-block text-truncate">Anket Yanıtı</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 rounded-4 border" style="background: rgba(255, 255, 255, 0.05); border-color: rgba(255, 255, 255, 0.08) !important;">
                            <div class="fs-2 fw-bold text-info" id="statCorrelation">@cmp.RankCorrelation.ToString("0.00")</div>
                            <small class="opacity-75 d-block text-truncate">Korelasyon</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 rounded-4 border" style="background: rgba(255, 255, 255, 0.05); border-color: rgba(255, 255, 255, 0.08) !important;">
                            <div class="fs-2 fw-bold text-success">8</div>
                            <small class="opacity-75 d-block text-truncate">Erasmus Şehri</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card premium-card mb-5">
    <div class="card-body p-4 p-md-5">
        <h4 class="fw-bold mb-4" style="color: var(--primary-navy);"><i class="bi bi-bar-chart-line-fill me-2 text-warning"></i>Model vs. Öğrenci Memnuniyeti</h4>
        <div id="comparisonChart" style="min-height:360px;"></div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-lg-6">
        <div class="card premium-card h-100">
            <div class="card-body p-4 p-md-5">
                <h5 class="fw-bold mb-4" style="color: var(--primary-navy);"><i class="bi bi-pie-chart-fill me-2 text-warning"></i>Öğrencilerin En Önemli Kriteri</h5>
                <div id="criterionChart" style="min-height:300px;"></div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card premium-card h-100">
            <div class="card-body p-4 p-md-5">
                <h5 class="fw-bold mb-4" style="color: var(--primary-navy);"><i class="bi bi-arrow-repeat me-2 text-warning"></i>Tekrar Seçme Oranı (%)</h5>
                <div id="againChart" style="min-height:300px;"></div>
            </div>
        </div>
    </div>
</div>

<div class="card premium-card mb-5">
    <div class="card-body p-4 p-md-5">
        <h4 class="fw-bold mb-4" style="color: var(--primary-navy);"><i class="bi bi-table me-2 text-warning"></i>Detaylı Karşılaştırma Tablosu</h4>
        <div class="table-responsive">
            <table class="table table-premium align-middle mb-0" id="comparisonTable">
                <thead>
                    <tr>
                        <th>Şehir</th>
                        <th>Model Sırası</th>
                        <th>Öğrenci Sırası</th>
                        <th>Memnuniyet (1-5)</th>
                        <th>Tekrar Seçme %</th>
                        <th>Uyum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in cmp.Rows)
                    {
                        var badgeClass = row.Alignment == "Tam Uyum" ? "badge-soft-success" : row.Alignment == "Yakın Uyum" ? "badge-soft-warning" : "badge-soft-secondary";
                        <tr>
                            <td class="fw-semibold" style="color: var(--primary-navy); font-size: 1.05rem;">@row.City</td>
                            <td><span class="badge bg-primary px-3 py-2 rounded-pill">#@row.ModelRank</span></td>
                            <td><span class="badge bg-info text-dark px-3 py-2 rounded-pill">#@(row.AlumniRank > 0 ? row.AlumniRank.ToString() : "-")</span></td>
                            <td class="fw-semibold">@(row.AlumniSatisfaction > 0 ? row.AlumniSatisfaction.ToString("0.0") : "-")</td>
                            <td class="fw-semibold">@(row.WouldChooseAgainPercent > 0 ? row.WouldChooseAgainPercent.ToString("0.0") + "%" : "-")</td>
                            <td><span class="badge @badgeClass">@row.Alignment</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    let comparisonData = @Html.Raw(JsonSerializer.Serialize(cmp, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));

    const criterionLabels = {
        cost: 'Ekonomi', security: 'Güvenlik', academic: 'Akademik', social: 'Sosyal'
    };

    let comparisonChart, criterionChart, againChart;

    function renderCharts(data) {
        const rows = data.rows.filter(r => r.alumniSatisfaction > 0);
        const cities = rows.map(r => r.city);
        const maxQ = Math.max(...rows.map(r => r.modelQScore), 0.001);
        const normModel = rows.map(r => ((1 - r.modelQScore / maxQ) * 5).toFixed(2));
        const alumniSat = rows.map(r => r.alumniSatisfaction);

        if (comparisonChart) comparisonChart.destroy();
        comparisonChart = new ApexCharts(document.querySelector('#comparisonChart'), {
            series: [
                { name: 'Model (normalize)', data: normModel },
                { name: 'Öğrenci Memnuniyeti', data: alumniSat }
            ],
            chart: { type: 'bar', height: 360, toolbar: { show: false }, fontFamily: "'Noto Sans', sans-serif" },
            plotOptions: { bar: { horizontal: false, columnWidth: '50%', borderRadius: 8 } },
            colors: ['#181e4b', '#f1a501'],
            xaxis: { categories: cities },
            yaxis: { max: 5, title: { text: 'Skor (1-5)' } },
            legend: { position: 'top' },
            dataLabels: { enabled: false }
        });
        comparisonChart.render();

        const critDist = data.criterionDistribution || {};
        const critKeys = Object.keys(critDist);
        if (criterionChart) criterionChart.destroy();
        criterionChart = new ApexCharts(document.querySelector('#criterionChart'), {
            series: critKeys.map(k => critDist[k]),
            labels: critKeys.map(k => criterionLabels[k] || k),
            chart: { type: 'donut', height: 300, fontFamily: "'Noto Sans', sans-serif" },
            colors: ['#f1a501', '#df6951', '#2b9348', '#181e4b'],
            legend: { position: 'bottom' }
        });
        criterionChart.render();

        if (againChart) againChart.destroy();
        againChart = new ApexCharts(document.querySelector('#againChart'), {
            series: [{ name: 'Tekrar Seçme %', data: rows.map(r => r.wouldChooseAgainPercent) }],
            chart: { type: 'bar', height: 300, toolbar: { show: false }, fontFamily: "'Noto Sans', sans-serif" },
            plotOptions: { bar: { borderRadius: 8, distributed: true } },
            colors: ['#2b9348', '#f1a501', '#181e4b', '#df6951', '#7209b7', '#4cc9f0', '#0d6efd', '#adb5bd'],
            xaxis: { categories: cities },
            yaxis: { max: 100 },
            legend: { show: false },
            dataLabels: { enabled: true, formatter: v => v + '%' }
        });
        againChart.render();

        document.getElementById('statResponses').textContent = data.totalResponses;
        document.getElementById('statCorrelation').textContent = data.rankCorrelation.toFixed(2);
        updateTable(data.rows);
    }

    function updateTable(rows) {
        const tbody = document.querySelector('#comparisonTable tbody');
        tbody.innerHTML = rows.map(r => {
            const badge = r.alignment === 'Tam Uyum' ? 'badge-soft-success' : r.alignment === 'Yakın Uyum' ? 'badge-soft-warning' : 'badge-soft-secondary';
            return `<tr>
                <td class="fw-semibold" style="color: var(--primary-navy); font-size: 1.05rem;">${r.city}</td>
                <td><span class="badge bg-primary px-3 py-2 rounded-pill">#${r.modelRank}</span></td>
                <td><span class="badge bg-info text-dark px-3 py-2 rounded-pill">#${r.alumniRank > 0 ? r.alumniRank : '-'}</span></td>
                <td class="fw-semibold">${r.alumniSatisfaction > 0 ? r.alumniSatisfaction.toFixed(1) : '-'}</td>
                <td class="fw-semibold">${r.wouldChooseAgainPercent > 0 ? r.wouldChooseAgainPercent.toFixed(1) + '%' : '-'}</td>
                <td><span class="badge ${badge}">${r.alignment}</span></td>
            </tr>`;
        }).join('');
    }

    document.getElementById('alumniForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const alert = document.getElementById('formAlert');
        const payload = {
            city: document.getElementById('city').value,
            satisfaction: parseInt(document.querySelector('input[name="satisfaction"]:checked').value),
            wouldChooseAgain: document.querySelector('input[name="again"]:checked').value === 'true',
            topCriterion: document.getElementById('criterion').value
        };

        try {
            const res = await fetch('/Deneyim?handler=Submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (res.ok && data.success) {
                alert.className = 'alert alert-success mt-3';
                alert.textContent = data.message;
                alert.classList.remove('d-none');
                comparisonData = data.comparison;
                renderCharts(comparisonData);
            } else {
                alert.className = 'alert alert-danger mt-3';
                alert.textContent = data.message || 'Kayıt sırasında hata oluştu.';
                alert.classList.remove('d-none');
            }
        } catch {
            alert.className = 'alert alert-danger mt-3';
            alert.textContent = 'Sunucuya bağlanılamadı.';
            alert.classList.remove('d-none');
        }
    });

    document.addEventListener('DOMContentLoaded', () => renderCharts(comparisonData));
</script>
